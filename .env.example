# 我的AI员工 - 环境变量模板
# 复制为 .env 并填入实际值（.env 已在 .gitignore）

# ===== LLM（D4.1 路由层 — v2 晨报钩子：国内模型优先）=====
# 数据驱动: 6 个国内 provider + 2 个国外 + 1 个本地
# 加新模型只改 src/my_ai_employee/ai/capability.py + 此处加 Key

# 国内（v2 钩子：连续 6 周调用量超美 / MiniMax M3 冲榜前 3）
# DeepSeek（连续 3 周 OpenRouter 第一，路由默认）
# DEEPSEEK_API_KEY=sk-...
# 通义千问 DashScope（1M context + 多模态）
# DASHSCOPE_API_KEY=sk-...
# 智谱 GLM（备选）
# GLM_API_KEY=...
# MiniMax M3（v2 钩子：首次冲进 OpenRouter 前 3）
# MINIMAX_API_KEY=...
# 腾讯混元（v2 钩子：多模态场景）
# TENCENT_API_KEY=...

# 国外（兜底 — 成本高，仅 fallback 用）
# OpenAI（1M context 兜底）
# OPENAI_API_KEY=sk-...
# Anthropic（Claude Sonnet 4.6 兜底）
# ANTHROPIC_API_KEY=sk-ant-...

# 本地（Ollama — 离线/隐私场景，无需 Key）
# OLLAMA_HOST=http://127.0.0.1:11434

# OpenAI-compatible 通用回退（多数 provider 都接受 OPENAI_API_KEY / OPENAI_BASE_URL）
# OPENAI_API_KEY=  # 兜底：未设置专用 Key 时回退到此
# OPENAI_BASE_URL=  # 兜底：未匹配 provider 时回退到此 base URL

# ===== IMAP（Week 1 D2 配置）=====
# IMAP_HOST=imap.qq.com
# IMAP_PORT=993
# IMAP_USER=your_qq@qq.com
# IMAP_PASSWORD=  # OAuth 走 Keychain，不填此项

# ===== CalDAV（Week 1 D5 配置）=====
# CALDAV_URL=https://caldav.icloud.com
# CALDAV_USER=your_apple_id@icloud.com
# CALDAV_PASSWORD=  # 应用专用密码，存 Keychain

# ===== 数据库（Week 1 D3 配置）=====
# DB_PATH=~/Library/Application Support/我的AI员工/data.db
# DB_ENCRYPTION_KEY=  # 首次运行从 Keychain 自动生成

# ===== 微信/支付宝（Week 2 D6/D7 配置）=====
# WECHAT_CSV_DIR=~/Documents/账单/微信
# ALIPAY_CSV_DIR=~/Documents/账单/支付宝

# ===== 笔记（Week 2 D9 配置）=====
# APPLE_NOTES_INCLUDE_FOLDERS=工作,生活,技术

# ===== 写操作门控（默认全关 = 安全默认；凭据仍走 Keychain）=====
# 完全体上线保留"默认安全"：以下开关默认不设 = dry-run / 拒写。
# 真实执行改为每次 1-click 审批时临时授权，**不建议**在此持久化打开。
# DASHBOARD_REAL_DB=       # 1 → Dashboard/菜单栏注入真实加密库（只读展示，安全）
# BUSINESS_WRITER_ENABLED= # 1 → 启用 BusinessWriter（配合 5 门）
# DASHBOARD_WRITE_API=     # 1 → 放开 POST 写 API（第 1 门）
# ENABLE_PATH_4_WRITE=     # 1 → Path4 实写第 5 门（红线：不写此文件，审批时临时授权）
# SMTP_REAL_NETWORK=       # 1 → 允许真实 SMTP 外发（红线：审批时临时授权）
# ENABLE_NOTES_ENCRYPTION= # 1 → Notes 字段级真加密（红线：需先跑 runbook 评估历史库）

# ===== 调试 =====
# DEBUG=0  # 1 开启详细日志
# LOG_LEVEL=INFO
