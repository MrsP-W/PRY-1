<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  P1 运行巡检 — 独立 one-shot LaunchAgent

  - RunAtLoad + StartInterval=600：登录后立即采样，此后约每 10 分钟一次
  - KeepAlive=false：业务不健康不触发 launchd 重启热循环
  - ProcessType=Standard：禁止 Background（App Nap/节流会把 15min 拖到 ~50min，撞 P3 health_sample_gap）
  - 不替代 menu-bar / Dashboard 的 KeepAlive；不执行任何服务启停
  - 系统睡眠仍会冻结 StartInterval；P3 长稳需机器保持醒着或另行 caffeinate
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.myaiemployee.health-monitor</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/$USER/bin/my-ai-employee-health-monitor-runner</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/$USER/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>HOME</key>
        <string>/Users/$USER</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>StartInterval</key>
    <integer>600</integer>

    <key>KeepAlive</key>
    <false/>

    <key>ProcessType</key>
    <string>Standard</string>

    <key>StandardOutPath</key>
    <string>/Users/$USER/Library/Logs/MyAIEmployee/health-monitor.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/$USER/Library/Logs/MyAIEmployee/health-monitor.err.log</string>

    <key>WorkingDirectory</key>
    <string>/Users/$USER</string>
</dict>
</plist>
